// Saic_networks clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace saic_networks {

    entity Case {
        id: string @unique
        number: string
        jurisdiction: string
        status: string
        filedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Party {
        id: string @unique
        caseId: string
        role: string
        name: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Document {
        id: string @unique
        caseId: string
        type: string
        contentRef: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Incident {
        id: string @unique
        type: string
        jurisdiction: string
        occurredAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Watchlist {
        id: string @unique
        name: string
        program: string
        entries: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Sanction {
        id: string @unique
        targetName: string
        program: string
        listedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
